# ---- Database (Postgres, 仅元数据) ----
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora
POSTGRES_DB=nexora
DATABASE_URL=postgresql+psycopg://nexora:nexora@postgres:5432/nexora

# ---- Redis (Celery) ----
REDIS_URL=redis://redis:6379/0

# ---- OpenSearch (向量 + 关键词混合检索) ----
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=nexora_chunks

# ---- Model server (独立嵌入服务) ----
MODEL_SERVER_URL=http://model_server:9000
EMBED_DIM=1024
# model_server 内部用 Ollama 做嵌入
EMBED_MODEL=bge-m3

# ---- Ollama ----
OLLAMA_BASE_URL=http://ollama:11434
# ollama-pull 拉取的生成模型 (compose 变量)
GEN_OLLAMA_MODEL=qwen2.5:3b

# ---- LLM (LiteLLM 模型串) ----
# ollama/qwen2.5:3b | anthropic/claude-sonnet-4-6 | openai/gpt-4o
LLM_MODEL=ollama/qwen2.5:3b
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Retrieval ----
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---- App ----
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:3000

# ---- Frontend (浏览器访问后端基址; api.ts 会自动加 /api) ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
