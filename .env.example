# ---- Database (Postgres + pgvector) ----
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora
POSTGRES_DB=nexora
# In docker-compose the host is the service name "postgres"
DATABASE_URL=postgresql+psycopg://nexora:nexora@postgres:5432/nexora

# ---- Redis (Celery broker / result backend) ----
REDIS_URL=redis://redis:6379/0

# ---- Ollama (本地 LLM 生成 + 嵌入) ----
OLLAMA_BASE_URL=http://ollama:11434
# 生成模型 (chat). 默认 qwen2.5:3b: 中文强、约 2GB, 在 Docker 内存 ~8GB 下可稳跑。
# 若 Docker 分配内存 >=12GB, 可换更强的 llama3.1 (8B, 权重 ~5GB, 内存不足会被 OOM 杀掉)。
GEN_MODEL=qwen2.5:3b
# 嵌入模型. bge-m3 多语言(含中文), 维度 1024
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ---- LLM provider 抽象: ollama | anthropic ----
LLM_PROVIDER=ollama
# 仅当 LLM_PROVIDER=anthropic 时需要
ANTHROPIC_API_KEY=

# ---- Retrieval ----
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---- App ----
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# 浏览器访问后端的地址 (compose 下经由宿主机端口)
NEXT_PUBLIC_API_BASE=http://localhost:8000
