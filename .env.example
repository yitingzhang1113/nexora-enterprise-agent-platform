# ---- Database (Postgres: 元数据 + chunk 文本) ----
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora
POSTGRES_DB=nexora
DATABASE_URL=postgresql+psycopg://nexora:nexora@postgres:5432/nexora

# ---- Redis (Celery + 短期记忆 + 限流) ----
REDIS_URL=redis://redis:6379/0

# ---- Milvus (向量库) ----
MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=nexora_chunks

# ---- Model server (嵌入) ----
MODEL_SERVER_URL=http://model_server:9000
EMBED_DIM=1024
OLLAMA_BASE_URL=http://ollama:11434
EMBED_MODEL=bge-m3
# ollama-pull 拉取的生成模型 (compose 变量)
GEN_OLLAMA_MODEL=qwen2.5:3b

# ---- LLM (LangChain). llm_router 按任务选模型 ----
LLM_PROVIDER=ollama
LLM_MODEL_MAIN=qwen2.5:3b
LLM_MODEL_FAST=qwen2.5:3b
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Retrieval / rerank ----
TOP_K=5
RETRIEVE_POOL=20
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RERANK_MODE=llm

# ---- MCP (留空则用内置 mock 工具) ----
MCP_SERVER_URL=

# ---- Langfuse (compose 已自动建项目并注入同名 key) ----
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-nexora
LANGFUSE_SECRET_KEY=sk-lf-nexora

# ---- App ----
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MIN=60

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_LANGFUSE_URL=http://localhost:3001
